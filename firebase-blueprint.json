{
  "entities": {
    "User": {
      "title": "User",
      "description": "Staff member or Admin",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "description": "Gmail address" },
        "role": { "type": "string", "enum": ["admin", "cashier"] },
        "status": { "type": "string", "enum": ["pending", "active", "blocked"] },
        "isSuperAdmin": { "type": "boolean" },
        "ownerId": { "type": "string", "description": "The Admin who owns this account (for cashiers)" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "status"]
    },
    "Ingredient": {
      "title": "Ingredient",
      "description": "Raw materials for products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "stockLevel": { "type": "number" },
        "unit": { "type": "string", "description": "g, ml, pcs, etc." },
        "costPerUnit": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "ownerId": { "type": "string", "description": "The Admin who owns this ingredient" }
      },
      "required": ["name", "stockLevel", "unit", "costPerUnit", "ownerId"]
    },
    "Product": {
      "title": "Product",
      "description": "Menu items",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "basePrice": { "type": "number" },
        "variations": {
          "type": "object",
          "description": "Size variations e.g. { 'Small': 0, 'Medium': 20, 'Large': 40 }"
        },
        "addOns": {
          "type": "object",
          "description": "Optional add-ons e.g. { 'Extra Shot': 15, 'Oat Milk': 20 }"
        },
        "recipe": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ingredientId": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "ownerId": { "type": "string", "description": "The Admin who owns this product" }
      },
      "required": ["name", "category", "basePrice", "ownerId"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Completed transaction",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "total": { "type": "number" },
        "discount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["Cash", "GCash", "Card"] },
        "staffId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "totalCost": { "type": "number" },
        "profit": { "type": "number" },
        "ownerId": { "type": "string", "description": "The Admin who owns this sale" }
      },
      "required": ["items", "total", "staffId", "timestamp", "ownerId"]
    },
    "PendingOrder": {
      "title": "PendingOrder",
      "description": "Created but not completed order",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "total": { "type": "number" },
        "discount": { "type": "number" },
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string", "description": "The Admin who owns this order" }
      },
      "required": ["items", "total", "staffId", "timestamp", "ownerId"]
    },
    "Shift": {
      "title": "Shift",
      "description": "Staff shift session",
      "type": "object",
      "properties": {
        "staffId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "totalSales": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "ownerId": { "type": "string", "description": "The Admin who owns this shift" }
      },
      "required": ["staffId", "startTime", "status", "ownerId"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Staff accounts" },
    "/ingredients/{ingredientId}": { "schema": "Ingredient", "description": "Inventory items" },
    "/products/{productId}": { "schema": "Product", "description": "Menu items" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Product categories" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Transaction history" },
    "/shifts/{shiftId}": { "schema": "Shift", "description": "Shift logs" },
    "/pendingOrders/{orderId}": { "schema": "PendingOrder", "description": "Created but not completed orders" }
  }
}
